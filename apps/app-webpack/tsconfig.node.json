{
  "compilerOptions": {
    "composite": true,
    "skipLibCheck": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "types": ["node"],

    "strictNullChecks": true
  },

  "ts-node": {
    "esm": true,
    "experimentalSpecifierResolution": "node",
    "logError": true,
    "pretty": true
  },

  "include": ["config/**/*.ts", "scripts/**/*.ts", "../../@types"]
}
