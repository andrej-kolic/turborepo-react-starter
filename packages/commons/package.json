{
  "name": "@repo/commons",
  "version": "0.0.0",
  "type": "module",
  "types": "./dist/index.d.ts",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "files": [
    "dist"
  ],
  "private": true,
  "license": "MIT",
  "scripts": {
    "bundle": "tsup-node",
    "bundle:watch": "tsup-node --watch",
    "type:gen": "tsc --emitDeclarationOnly",
    "type:gen:watch": "tsc --emitDeclarationOnly --watch",
    "clear:output": "rm -rf dist tsconfig.tsbuildinfo",
    "build": "pnpm clear:output && run-p bundle type:gen",
    "dev": "run-p bundle:watch type:gen:watch",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "check:type": "tsc --noEmit && tsc --noEmit -p tsconfig.test.json",
    "check:type:go": "tsgo --noEmit && tsgo --noEmit -p tsconfig.test.json",
    "publint": "pnpm dlx publint"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@turbo/gen": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "npm-run-all": "4.1.5",
    "tsup": "8.5.1",
    "vitest": "catalog:"
  }
}
