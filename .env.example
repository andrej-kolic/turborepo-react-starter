HELLO=Monorepo
BUILD_ENVIRONMENT=staging
BUNDLER="app-vite"
STORYBOOK_OPTIONS="--docs"

NODE_DEBUG="app-esbuild,dev-tools,app-webpack,app-vite"

# --- Browser validation ---
# URL used by pnpm dev:app (default: Vite on 5173). Override for remote/deployed targets.
APP_DEV_URL=http://localhost:5173

# URL used by pnpm browser:validate / browser:read when --url is not passed explicitly.
# Set to a deployed preview URL in CI or remote environments.
# (Phase 2b) — not yet read by any script; set it in preparation for browser:validate CLI.
APP_VALIDATE_URL=http://localhost:5173

# Chrome remote-debugging host and port (must match pnpm chrome:debug settings).
CHROME_DEBUG_HOST=localhost
CHROME_DEBUG_PORT=9222

# Set to "true" to start Chrome without a visible window (headless mode).
# Useful for CI pipelines and Cloud Agent sessions.
CHROME_HEADLESS=false
