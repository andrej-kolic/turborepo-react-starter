HELLO=Monorepo
BUILD_ENVIRONMENT=staging
BUNDLER="app-vite"
STORYBOOK_OPTIONS="--docs"

NODE_DEBUG="app-esbuild,dev-tools,app-webpack,app-vite"

# --- Browser validation ---
# App URL is not stored here — pnpm browser:* scripts derive APP_URL from BUNDLER via
# @repo/dev-tools/config/app-port.js (app-vite → 5173, app-webpack → 8080, app-esbuild → 8000).
# Agents: pnpm browser:ensure-app then omit --url on pnpm browser validate/read/eval.
# Override when --url is omitted (preview, remote deploy, custom port):
# APP_URL=https://your-preview.netlify.app

# Chrome remote-debugging host and port (must match pnpm chrome:debug settings).
CHROME_DEBUG_HOST=localhost
CHROME_DEBUG_PORT=9222

# Set to "true" to start Chrome without a visible window (headless mode).
# Useful for CI pipelines and Cloud Agent sessions.
CHROME_HEADLESS=false
