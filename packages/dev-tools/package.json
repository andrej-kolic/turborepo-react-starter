{
  "name": "@repo/dev-tools",
  "description": "Workspace-aware dev config and CLI helpers (ports, env, paths).",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "exports": {
    "./config/app-port": "./config/app-port.ts",
    "./config/environment": "./config/environment.ts",
    "./config/paths": "./config/paths.ts"
  },
  "bin": {
    "dev-tools-app-target": "./bin/app-target.js"
  },
  "scripts": {
    "check:type": "tsc --noEmit && tsc --noEmit -p tsconfig.test.json",
    "check:type:go": "tsgo --noEmit && tsgo --noEmit -p tsconfig.test.json",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@types/node": "catalog:",
    "dotenv-flow": "4.1.0",
    "tsx": "catalog:",
    "vitest": "catalog:"
  }
}
