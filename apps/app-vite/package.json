{
  "name": "app-vite",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "devPort": 5173,
  "previewPort": 4173,
  "scripts": {
    "dev": "vite --configLoader runner --mode ${BUILD_ENVIRONMENT}",
    "build": "tsc && vite build --configLoader runner --mode ${BUILD_ENVIRONMENT}",
