{
  "name": "app-webpack",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "devPort": 8080,
  "previewPort": 8081,
  "scripts": {
    "_bundle_dev": "tsx node_modules/webpack-cli/bin/cli.js serve --mode development --config config/webpack.config.ts",
    "_bundle_build": "tsx node_modules/webpack-cli/bin/cli.js --mode production --config config/webpack.config.ts",
    "dev": "NODE_ENV=development pnpm _bundle_dev",
    "build": "NODE_ENV=production pnpm _bundle_build",
    "preview": "tsx ./scripts/preview.ts",
    "lint": "eslint .",
    "check:type": "tsc --noEmit",
    "check:type:go": "tsgo --noEmit",
    "clear:output": "rm -rf ./dist"
  },
  "dependencies": {
    "@repo/app-core": "workspace:*",
    "react": "catalog:",
    "react-dom": "catalog:"
  },
  "devDependencies": {
    "@repo/dev-tools": "workspace:*",
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "copy-webpack-plugin": "14.0.0",
    "css-loader": "7.1.4",
    "html-webpack-plugin": "5.6.7",
    "mini-css-extract-plugin": "2.10.2",
    "ts-loader": "9.6.1",
    "serve": "catalog:",
    "tsx": "catalog:",
    "webpack": "5.107.2",
    "webpack-cli": "7.0.3",
    "webpack-dev-server": "5.2.5"
  }
}
