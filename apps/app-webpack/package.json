{
  "name": "app-webpack",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "devPort": 8080,
  "previewPort": 8081,
  "scripts": {
    "dev": "NODE_OPTIONS='--loader ts-node/esm' NODE_ENV=development webpack serve --mode development --config config/webpack.config.ts",
    "build": "NODE_OPTIONS='--loader ts-node/esm' NODE_ENV=production webpack --mode production --config config/webpack.config.ts",
    "preview": "TS_NODE_PROJECT=tsconfig.node.json node --loader ts-node/esm ./scripts/preview.ts",
    "lint": "eslint .",
    "check:type": "tsc --noEmit",
    "check:type:go": "tsgo --noEmit",
    "clear:output": "rm -rf ./dist"
  },
  "dependencies": {
    "@repo/app-core": "workspace:*",
    "react": "catalog:",
    "react-dom": "catalog:"
  },
  "devDependencies": {
    "@repo/dev-tools": "workspace:*",
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "copy-webpack-plugin": "14.0.0",
    "css-loader": "7.1.4",
    "html-webpack-plugin": "5.6.7",
    "mini-css-extract-plugin": "2.10.2",
    "ts-loader": "9.5.7",
    "serve": "catalog:",
    "ts-node": "catalog:",
    "webpack": "5.107.2",
    "webpack-cli": "7.0.2",
    "webpack-dev-server": "5.2.4"
  }
}
