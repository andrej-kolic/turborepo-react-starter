  },
  "devDependencies": {
    "@repo/dev-tools": "workspace:*",
    "@repo/eslint-config": "workspace:*",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react": "6.0.2",
    "vite": "catalog:"
  },
  "_devDependencies": {
    "eslint-plugin-react-refresh": "^0.4.12"
  }
}
